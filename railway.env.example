# Variables recomendadas para Railway
# Configuralas en Railway > tu servicio > Variables.
# No subas un archivo .env real a GitHub.

NODE_ENV=production
SESSION_SECRET=pon_aqui_un_valor_largo_y_aleatorio

# Railway PostgreSQL suele exponer DATABASE_URL automaticamente si conectas el servicio Postgres.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Activa SSL solo si tu conexion externa a PostgreSQL lo requiere.
# Para Railway interno normalmente puedes dejarla sin definir.
# DB_SSL=true

# Sustituye por la URL publica real de Railway cuando la tengas.
CLIENT_ORIGIN=https://tu-app.up.railway.app

# OAuth solo si vas a habilitar login con Google en produccion.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://tu-app.up.railway.app/auth/google/callback

# Backoffice admin
ADMIN_USER=admin@tfgdemo.com
ADMIN_PASSWORD=Admin123!
