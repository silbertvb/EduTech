# Copia este archivo como .env para desarrollo local.
# En Railway no subas un .env real: configura estas variables en Variables.

# Servidor
NODE_ENV=development
PORT=3000

# PostgreSQL local
DB_HOST=localhost
DB_PORT=5434
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=elearning_platform

# PostgreSQL en Railway
# Si Railway proporciona DATABASE_URL, el backend la usara antes que DB_HOST/DB_PORT/etc.
# DATABASE_URL=postgresql://usuario:password@host:puerto/bbdd
# DB_SSL=true

# Sesion
SESSION_SECRET=change_me_for_a_long_random_secret

# Google OAuth
# Local:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5173/auth/google/callback

# Frontend / URL publica
# Local:
CLIENT_ORIGIN=http://localhost:5173
# Railway:
# CLIENT_ORIGIN=https://tu-app.up.railway.app
# GOOGLE_CALLBACK_URL=https://tu-app.up.railway.app/auth/google/callback

# Backoffice admin
ADMIN_USER=admin@tfgdemo.com
ADMIN_PASSWORD=Admin123!
