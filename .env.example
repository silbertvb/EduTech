# Copia este archivo como .env para desarrollo local.
# En Render no subas un .env real: configura estas variables en el dashboard (Environment).

# Servidor
NODE_ENV=development
PORT=3000

# PostgreSQL local (docker-compose)
DB_HOST=localhost
DB_PORT=5434
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=elearning_platform

# PostgreSQL en Neon (produccion)
# Neon entrega una connection string tipo:
# postgresql://usuario:password@ep-xxxx.neon.tech/edutech?sslmode=require
# Si DATABASE_URL esta definida, el backend la usa en vez de DB_HOST/DB_PORT/etc.
# DATABASE_URL=postgresql://usuario:password@host/basededatos?sslmode=require
# DB_SSL=true

# Sesion
SESSION_SECRET=change_me_for_a_long_random_secret

# Google OAuth
# Local:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5173/auth/google/callback
# Produccion (Render): el callback real se calcula en tiempo de ejecucion a partir
# del host de la request (ver apps/backend/routes/auth.routes.js), pero estas
# variables deben tener algun valor no vacio para que el login con Google se active.
# GOOGLE_CALLBACK_URL=https://tu-app.onrender.com/auth/google/callback

# Frontend / URL publica
# Local:
CLIENT_ORIGIN=http://localhost:5173
# Render:
# CLIENT_ORIGIN=https://tu-app.onrender.com

# Backoffice admin
ADMIN_USER=admin@tfgdemo.com
ADMIN_PASSWORD=Admin123!